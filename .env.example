# PANEL CONFIGURATION
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Panel Service Port
PANEL_PORT=7860

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# DASHBOARD CONNECTION (REPLACED ghost.devdot.qzz.io)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# For local development (same machine):
DASHBOARD_URL=http://localhost:7861

# For production (via Cloudflare tunnel):
# DASHBOARD_URL=https://dashboard.jujulefek.qzz.io

# Panel will connect to DASHBOARD_URL for:
# - /api/register (register panel)
# - /api/report (send status updates)
# - /api/ack (acknowledge receipt)
# - /api/dashboard/events (send events)

AUTH_KEY=GHOST_SECRET_2026

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
